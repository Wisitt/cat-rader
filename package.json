{
  "name": "petradar",
  "private": true,
  "packageManager": "npm@10.2.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:admin": "npm run dev --workspace apps/admin",
    "dev:api": "npm run dev --workspace apps/api",
    "lint": "turbo run lint",
    "test:functional": "node tests/functional.test.mjs",
    "test": "npm run test:functional"
  },
  "devDependencies": {
    "turbo": "^2.0.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
